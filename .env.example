# 火山引擎 API 密钥（必须填写）
ARK_API_KEY=your_api_key_here

# DeepSeek API 密钥（文案生成、文案改写、图文一体文案部分必须填写）
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# gpt-image-2 API（独立生图页使用，OpenAI 兼容接口）
XI_XU_API_BASE_URL=https://api.xi-xu.me
XI_XU_API_KEY=your_xi_xu_api_key_here
XI_XU_IMAGE_MODEL=gpt-image-2
XI_XU_VISION_MODEL=gpt-5.5
XI_XU_GENERATE_TIMEOUT_MS=1800000
XI_XU_GENERATE_RETRIES=1
XI_XU_EDIT_TIMEOUT_MS=180000
XI_XU_EDIT_RETRIES=1
XI_XU_EDIT_FORCE_FALLBACK=false
XI_XU_EDIT_CIRCUIT_BREAKER_MS=120000
ARK_FALLBACK_ENABLED=true
XI_XU_MAX_ACTIVE_JOBS=0
MAX_UPLOAD_IMAGE_MB=10

# JWT 登录密钥（生产环境必须使用高强度随机字符串）
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# 初始管理员账号（首次启动创建管理员时使用）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_a_strong_password

# 允许的来源域名（生产环境使用，多个用逗号分隔，留空则允许所有同源请求）
# 示例: https://example.com 或 https://example.com,https://www.example.com
# ALLOWED_ORIGIN=https://your-domain.com

# 服务端口（生产环境当前使用 3001，本地默认可用 3001）
# PORT=3001

# 仅用于本地/测试的模拟支付回调保护令牌。
# 生产环境不应使用模拟回调；如果临时开启 ENABLE_MOCK_PAYMENT=true，必须同时配置该令牌。
# MOCK_PAYMENT_TOKEN=replace_with_a_long_random_token
